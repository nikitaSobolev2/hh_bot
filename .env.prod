# Public HH API (scraper): stable app id — required format per https://github.com/hhru/api
# HH_USER_AGENT=MyBot/1.0 (you@example.com)
# Parallel GET /vacancies/{id} per job — lower if you see HTTP 403 from api.hh.ru
# HH_VACANCY_DETAIL_CONCURRENCY=5

# HH UI apply (Playwright). Daily apply cap: Admin → App settings (not .env).
HH_UI_APPLY_ENABLED=true
# Debug Playwright screenshots on disk and "send error screenshot to user" are toggled in Admin → App settings (DB), not here.

# Docker: hh_ui Celery worker concurrency (default 1)
# CELERY_HH_UI_CONCURRENCY=1

# Login assist: see docs/HH_LOGIN_ASSIST.md; compose service celery_worker_login_assist, noVNC port:
# LOGIN_ASSIST_NOVNC_PORT=6080
# Optional VNC password for x11vnc (prefer reverse-proxy auth in production):
# LOGIN_ASSIST_VNC_PASSWORD=
# Set to true on production hosts so the container exits if no VNC password is set (no -nopw):
# LOGIN_ASSIST_REQUIRE_VNC_PASSWORD=true

HH_LOGIN_ASSIST_ENABLED=true
HH_LOGIN_ASSIST_HEADLESS=false
HH_LOGIN_ASSIST_VIEWER_URL=http://138.124.32.109:6080/vnc.html