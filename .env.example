# Telegram
BOT_TOKEN=your-telegram-bot-token

# PostgreSQL (POSTGRES_USER/PASSWORD/DB must match docker-compose postgres service)
POSTGRES_USER=hh_bot
POSTGRES_PASSWORD=hh_bot_secret
POSTGRES_DB=hh_bot
# From the host machine use localhost; in Docker use hostname ``postgres`` (see docker-compose).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (use hostname "redis" in Docker)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# OpenAI
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Logging / support
LOG_LEVEL=INFO
LOG_TELEGRAM_CHAT_ID=
SUPPORT_CHAT_ID=

# Admin (comma-separated Telegram user IDs)
ADMIN_TELEGRAM_IDS=123456789

# Fernet key for HH browser storage / tokens
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HH_TOKEN_ENCRYPTION_KEY=

# Public HH API (scraper): stable app id — required format per https://github.com/hhru/api
# HH_USER_AGENT=MyBot/1.0 (you@example.com)
# Parallel GET /vacancies/{id} per job — lower if you see HTTP 403 from api.hh.ru
# HH_VACANCY_DETAIL_CONCURRENCY=5

# HH UI apply (Playwright). Daily apply cap: Admin → App settings (not .env).
HH_UI_APPLY_ENABLED=false
# Debug Playwright screenshots on disk and "send error screenshot to user" are toggled in Admin → App settings (DB), not here.

# Docker: hh_ui Celery worker concurrency (default 1)
# CELERY_HH_UI_CONCURRENCY=1

# Login assist: see docs/HH_LOGIN_ASSIST.md; compose service celery_worker_login_assist, noVNC port:
# LOGIN_ASSIST_NOVNC_PORT=6080
