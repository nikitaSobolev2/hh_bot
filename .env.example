# Telegram
BOT_TOKEN=your-telegram-bot-token

# PostgreSQL
POSTGRES_USER=hh_bot
POSTGRES_PASSWORD=hh_bot_secret
POSTGRES_DB=hh_bot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis — use hostname "redis" when running via docker compose (bot/celery containers).
# On the VM, do not set this to a remote host unless that Redis is a writable primary.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# OpenAI
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Logging
LOG_LEVEL=INFO
LOG_TELEGRAM_CHAT_ID=
SUPPORT_CHAT_ID=

# Admin
ADMIN_TELEGRAM_IDS=123456789

# Fernet key — encrypts Playwright browser storage and (if used) OAuth tokens
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HH_TOKEN_ENCRYPTION_KEY=rF2yEdp7yRcGLO5uGgUSsOvU4NXK7VDVepC1uso1nQk=

# HH UI apply (Playwright) — set HH_UI_APPLY_ENABLED=true after alembic upgrade + playwright install chromium
# HH_UI_APPLY_MAX_PER_DAY=50
# HH_UI_HEADLESS=true
HH_UI_APPLY_ENABLED=false

# HH server-side login assist (Telegram flow; requires UI apply + Fernet key; see docs/HH_LOGIN_ASSIST.md)
# Run docker compose service `celery_worker_login_assist` (Xvfb + noVNC on port 6080 by default).
# HH_LOGIN_ASSIST_ENABLED=false
# HH_LOGIN_ASSIST_MAX_WAIT_SECONDS=900
# HH_LOGIN_ASSIST_POLL_INTERVAL_SECONDS=2
# HH_LOGIN_ASSIST_MAX_PER_DAY=5
# HH_LOGIN_ASSIST_LOGIN_URL=https://hh.ru/account/login
# URL shown in Telegram — must reach websockify/noVNC (e.g. https://your-domain/vnc.html or http://SERVER_IP:6080/vnc.html)
# HH_LOGIN_ASSIST_VIEWER_URL=
# Headed Chromium on the login-assist worker; compose sets HH_LOGIN_ASSIST_HEADLESS=false for that service
# HH_LOGIN_ASSIST_HEADLESS=true
# Host port mapped to noVNC (docker-compose `celery_worker_login_assist`)
# LOGIN_ASSIST_NOVNC_PORT=6080
# Optional VNC password for x11vnc (prefer TLS + proxy auth in production)
# LOGIN_ASSIST_VNC_PASSWORD=
