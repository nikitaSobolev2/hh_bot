# Telegram
BOT_TOKEN=your-telegram-bot-token

# PostgreSQL
POSTGRES_USER=hh_bot
POSTGRES_PASSWORD=hh_bot_secret
POSTGRES_DB=hh_bot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis — use hostname "redis" when running via docker compose (bot/celery containers).
# On the VM, do not set this to a remote host unless that Redis is a writable primary.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# OpenAI
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Logging
LOG_LEVEL=INFO
LOG_TELEGRAM_CHAT_ID=
SUPPORT_CHAT_ID=

# Admin
ADMIN_TELEGRAM_IDS=123456789
